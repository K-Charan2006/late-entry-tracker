{
  "name": "late-entry-tracker-root",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "NODE_ENV=production npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.1",
    "@types/node": "^22.14.0",
    "@types/express": "^4.17.21"
  }
}